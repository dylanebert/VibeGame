<sequence name="intro">
  <tween target="camera" attr="orbit-camera.target-yaw" to="0.6" duration="1.2" easing="expo-out"></tween>
  <tween target="camera" attr="orbit-camera.target-distance" to="10" duration="1.2" easing="expo-out"></tween>
  <tween target="camera" attr="orbit-camera.target-pitch" to="0.4" duration="1.2" easing="expo-out"></tween>
</sequence>

<sequence name="reset">
  <tween target="camera" attr="orbit-camera.target-yaw" to="2.0" duration="0.8" easing="expo-out"></tween>
  <tween target="camera" attr="orbit-camera.target-distance" to="25" duration="0.8" easing="expo-out"></tween>
  <tween target="camera" attr="orbit-camera.target-pitch" to="0.2" duration="0.8" easing="expo-out"></tween>
</sequence>
